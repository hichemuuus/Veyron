# PAIOS environment variables. Copy to .env and edit. .env is gitignored.
# Env vars use the PAIOS_ prefix and __ for nesting. They override config.yaml.

# PAIOS_ENVIRONMENT=dev
# PAIOS_DATABASE_URL=sqlite:///backend/data/paios.db

# PAIOS_MODEL__OLLAMA_URL=http://localhost:11434
# PAIOS_MODEL__BASE_MODEL=qwen2.5:3b-instruct

# PAIOS_SECURITY__CONFIRM_TIMEOUT_SECONDS=120
# PAIOS_SECURITY__SANDBOX_ROOTS=["C:\\Users\\YourUsername"]
