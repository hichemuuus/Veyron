{
  "identifier": "default",
  "description": "Default capabilities for Veyron Desktop",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "dialog:default"
  ]
}
